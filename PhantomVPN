LOG_DIR="/tmp/phantomvpn"
LOG_FILE="$LOG_DIR/phantomvpn.log"
PING_TARGET="8.8.8.8"
VPN_PEER="REMOTE_PEER_IP_HERE"
MTU_TEST_HOST="1.1.1.1"

mkdir -p $LOG_DIR

clear

echo "
